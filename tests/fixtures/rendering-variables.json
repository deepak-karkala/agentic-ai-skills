{
  "_comment": "Canonical variable registry for all 5 artifact templates. Lists every scalar variable and block name per template. The validator (validate-plugin.sh section 9) checks that this file exists and that rendered outputs in examples/outputs/ are present and placeholder-clean. It does not parse this registry — this file serves as a human-readable reference for skill authors implementing template rendering.",
  "_rendering_contract": {
    "scalar_substitution": "{{VARIABLE_NAME}} is replaced with a plain string. HTML-sensitive characters (&, <, >) must be escaped in HTML templates.",
    "block_repetition_open": "{{#BLOCK_NAME}} marks the start of a repeated section.",
    "block_repetition_close": "{{/BLOCK_NAME}} marks the end of a repeated section.",
    "zero_iteration": "A {{#BLOCK_NAME}}...{{/BLOCK_NAME}} section with zero items must be omitted entirely from rendered output.",
    "unreplaced_check": "Any rendered output containing the literal string '{{' is invalid and must be rejected before writing."
  },

